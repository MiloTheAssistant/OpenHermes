# Root environment template for OpenHermes deployment and local operations.
# TEMPLATE ONLY: copy this file to `.env` and fill in real values locally.
# Create the real file with `cp .env.example .env` before deployment or local testing.

# === Milo (Nous Hermes Front Door) ===
# From ollama.com > Account Settings > API Keys. Primary provider for Milo.
OLLAMA_API_KEY="<paste-ollama-api-key-here>"
# From build.nvidia.com. Fallback provider for Milo; keys are typically `nvapi-...`.
NVIDIA_NIM_API_KEY="<paste-nvapi-key-here>"

# === Elon (OpenClaw Orchestrator) ===
# From the Z.ai dashboard > GLM Coding Plan > API Keys. Tier-3 fallback only.
ZAI_CODING_PLAN_KEY="<paste-zai-coding-plan-key-here>"

# === Bridge Authentication ===
# Generated during deployment so Milo can call Elon's OpenAI-compatible gateway.
OPENCLAW_GATEWAY_TOKEN="<generate-openclaw-gateway-token>"
# Generated during bridge setup so Elon can call Milo's MCP surface.
MILO_MCP_TOKEN="<generate-milo-mcp-token>"
# Generated during deployment so Caddy can enforce bearer-token edge auth.
OPENHERMES_EDGE_TOKEN="<generate-openhermes-edge-token>"

# === Per-Agent Write Credentials ===
# Dedicated Twitter/X API bearer token used only by Zuck for publishing.
ZUCK_TWITTER_TOKEN="<paste-zuck-twitter-token-here>"
# Dedicated LinkedIn API token used only by Zuck for publishing.
ZUCK_LINKEDIN_TOKEN="<paste-zuck-linkedin-token-here>"
# Gmail OAuth token used by Milo for outbound email actions.
MILO_GMAIL_TOKEN="<paste-milo-gmail-token-here>"
# Slack bot token used by Milo for direct-message actions.
MILO_SLACK_TOKEN="<paste-milo-slack-token-here>"

# === Observability (Optional) ===
# Optional NDJSON ingest endpoint for centralized log forwarding; leave blank for local-only logging.
SIEM_ENDPOINT=""

# === Deployment ===
# Public domain used by Caddy for automatic HTTPS on the OpenHermes edge.
OPENHERMES_DOMAIN="openhermes.example.com"
