# Environment template for the Milo container only.
# TEMPLATE ONLY: copy this file to `milo.env` and fill in real values locally.
# Create the real file with `cp milo.env.example milo.env` before running the container.

# === Providers ===
# From ollama.com > Account Settings > API Keys. Primary provider for Milo.
OLLAMA_API_KEY="<paste-ollama-api-key-here>"
# From build.nvidia.com. Fallback provider for Milo; keys are typically `nvapi-...`.
NVIDIA_NIM_API_KEY="<paste-nvapi-key-here>"

# === Bridge Access ===
# Generated during deployment so Milo can call Elon's OpenAI-compatible gateway.
OPENCLAW_GATEWAY_TOKEN="<generate-openclaw-gateway-token>"

# === Messaging Credentials ===
# Gmail OAuth token used by Milo for outbound email actions.
MILO_GMAIL_TOKEN="<paste-milo-gmail-token-here>"
# Slack bot token used by Milo for direct-message actions.
MILO_SLACK_TOKEN="<paste-milo-slack-token-here>"

# === Observability (Optional) ===
# Optional NDJSON ingest endpoint for centralized log forwarding; leave blank for local-only logging.
SIEM_ENDPOINT=""
